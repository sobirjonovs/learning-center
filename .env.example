# Lokal ishlab chiqish
# DATABASE_URL="file:./dev.db"

# ---- Railway / Docker (production) ----
# Railway → Variables bo'limiga qo'shing (Build va Runtime uchun):
  DATABASE_URL = file:/data/learning-center.db
  NODE_ENV     = production
#
# Railway → Settings → Volume qo'shing:
#   Mount path: /data
#
# Birinchi deploydan keyin (faqat bir marta, Railway Shell orqali):
#   npm run db:init
#
# Keyingi deploylar avtomatik: npm run build → npm start
