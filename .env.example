# Lokal ishlab chiqish
# DATABASE_URL="file:./dev.db"

# ---- Railway / Docker (production) ----
# Railway → Variables bo'limiga qo'shing (Build va Runtime uchun):
  DATABASE_URL = file:/data/learning-center.db
  NODE_ENV     = production
#
# Railway → Settings → Volume qo'shing:
#   Mount path: /data
#
# Birinchi marta yoki bazani tozalash (Railway Shell):
#   CONFIRM_FRESH=true npm run db:fresh
#
# Ixtiyoriy admin ma'lumotlari:
#   ADMIN_LOGIN=admin
#   ADMIN_PASSWORD=your-secure-password
#   ADMIN_NAME=Administrator
