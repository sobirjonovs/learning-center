# Lokal ishlab chiqish
# DATABASE_URL="file:./dev.db"

# ---- Docker / server (production) ----
# Konteyner ichida /app har deployda yangilanadi — bazani /data ga saqlang!
# Platformada "Persistent Volume" ni /data ga ulang, keyin:
DATABASE_URL="file:/data/learning-center.db"
NODE_ENV="production"

# Birinchi marta (root sifatida, sudo kerak emas):
#   mkdir -p /data
# Keyin faqat bir marta:
#   npm run db:init
# Har deployda:
#   npm install && npm run start:prod
